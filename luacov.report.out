    5 	if type(err) ~= "table" then
    1 		return tostring(err)
      	end
      	
    4 	local lines = {}
      	
      	-- Main error message
    4 	if err.message then
    4 		table.insert(lines, "Error: " .. err.message)
      	end
      	
      	-- URL attempted
    4 	if err.url then
    2 		table.insert(lines, "URL: " .. err.url)
      	end
      	
      	-- HTTP status code with description
    4 	if err.http_code then
    2 		local code_desc = {
      			[404] = " (Not Found)",
    8 			[403] = " (Forbidden)",
    8 			[401] = " (Unauthorized)",
      			[500] = " (Server Error)",
      			[502] = " (Bad Gateway)",
   16 			[503] = " (Service Unavailable)",
      			[504] = " (Gateway Timeout)",
      		}
    2 		local desc = code_desc[err.http_code] or ""
    2 		table.insert(lines, "HTTP Code: " .. err.http_code .. desc)
      	end
      	
      	-- Tool used
    4 	if err.tool then
    1 		table.insert(lines, "Download Tool: " .. err.tool)
      	end
      	
      	-- Exit code
    4 	if err.exit_code then
    1 		table.insert(lines, "Exit Code: " .. err.exit_code)
      	end
      	
      	-- Additional error details (stderr)
   20 	if err.stderr and err.stderr ~= "" and err.stderr ~= err.message then
    1 		local stderr_preview = err.stderr:sub(1, 200)
    1 		if #err.stderr > 200 then
    1 			stderr_preview = stderr_preview .. "..."
      		end
    1 		table.insert(lines, "Details: " .. stderr_preview)
      	end
      	
   92 	return table.concat(lines, "\n  ")
      end

      -- Get suggested fix based on error type
