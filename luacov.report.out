      ---Version management for Hermes binaries
      ---@module hermes.version

  320 local M = {}

      ---Get the version to use
      ---Returns either user-specified version or "latest" as default
      ---@return string version Version string (e.g., "v0.1.0" or "latest")
   85 function M.get_wanted()
  263 	local config = require("hermes.config").get()
   28 	local wanted = config.version or "latest"

  263 	if wanted == "latest" then
   18 		return "latest"
      	end

      	-- Ensure version starts with 'v'
   10 	if not wanted:match("^v") then
    5 		wanted = "v" .. wanted
      	end

  101 	return wanted
      end

      ---Fetch latest release version from GitHub
      ---@return string version Latest version tag (e.g., "v0.1.0")
   85 function M.fetch_latest()
   23 	local logging = require("hermes.logging")
   23 	local fallback_version = "v0.1.0"

   31 	logging.notify("Fetching latest Hermes version from GitHub...", vim.log.levels.INFO)

      	-- Use download module for cross-platform HTTP support
   39 	local download = require("hermes.download")
  258 	local url = "https://api.github.com/repos/Ruddickmg/hermes.nvim/releases/latest"
      	
      	-- Create a temporary file for the response
   23 	local temp_file = os.tmpname()
      	
   23 	local success, err = download.download(url, temp_file)
      	
   23 	if not success then
   88 		logging.notify("Failed to fetch latest version: " .. (err or "Unknown error") .. ". Using fallback.", vim.log.levels.WARN)
   13 		os.remove(temp_file)
   13 		return fallback_version
      	end

      	-- Read the response
   10 	local f = io.open(temp_file, "r")
   10 	if not f then
   75 		logging.notify("Could not read version response. Using fallback.", vim.log.levels.WARN)
   75 		os.remove(temp_file)
****0 		return fallback_version
      	end
      	
   10 	local result = f:read("*all")
   85 	f:close()
      	
      	-- Clean up temp file
   34 	os.remove(temp_file)

      	-- Parse JSON response (simple pattern matching)
   10 	local tag = result:match('"tag_name":%s*"([^"]+)"')

   10 	if not tag then
   56 		logging.notify("Could not parse version from response. Using fallback.", vim.log.levels.WARN)
   56 		return fallback_version
      	end

    5 	logging.notify("Latest version: " .. tag, vim.log.levels.INFO)

    5 	return tag
      end

   85 return M

