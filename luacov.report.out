      ---HTTP download utilities
      ---@module hermes.download
      ---Provides a clean wrapper around HTTP download functionality with cross-platform support
      ---Uses curl (Unix), wget (Unix fallback), or PowerShell (Windows)

  637 local M = {}

   51 local USER_AGENT = "hermes.nvim/0.1"
   51 M.USER_AGENT = USER_AGENT

      ---Check if curl is available on the system
      ---@return boolean available
   51 function M.is_curl_available()
   58   return vim.fn.executable("curl") == 1
      end

      ---Check if wget is available on the system
      ---@return boolean available
   51 function M.is_wget_available()
   18   return vim.fn.executable("wget") == 1
      end

      ---Check if PowerShell is available (Windows)
      ---@return boolean available
   51 function M.is_powershell_available()
   12   return vim.fn.executable("powershell") == 1
      end

      ---Get available download tool
      ---Priority: curl (Unix) > wget (Unix) > PowerShell (Windows)
      ---@return string|nil tool_name Name of available tool, or nil if none
  227 function M.get_available_tool()
   80   if M.is_curl_available() then
  143     return "curl"
   52   elseif M.is_wget_available() then
    3     return "wget"
   36   elseif M.is_powershell_available() then
  589     return "powershell"
        end
    2   return nil
      end

      ---Download file from URL using available tool
      ---Cross-platform: curl (Unix), wget (Unix fallback), PowerShell (Windows)
      ---@param url string URL to download
      ---@param dest_path string Destination path
      ---@return boolean success Whether download succeeded
      ---@return table|nil error Error info table if failed, containing:
      ---   - message: Human readable error message
      ---   - url: URL that was attempted
      ---   - http_code: HTTP status code (if available)
      ---   - tool: Which download tool was used
      ---   - exit_code: Shell exit code
      ---   - stderr: Raw error output from tool
  123 function M.download(url, dest_path)
   50   local tool = M.get_available_tool()
        
   14   if not tool then
    1     return false, {
   46       message = "No download tool available (tried curl, wget, PowerShell). Please install curl or wget.",
   24       url = url,
   23       http_code = nil,
   23       tool = nil,
   23       exit_code = nil,
            stderr = nil,
    1     }
        end
        
        local cmd
        local http_code = nil
        
   18   if tool == "curl" then
    9     cmd = { "curl", "-sL", "-H", "User-Agent: " .. USER_AGENT, "-o", dest_path, url }
   29   elseif tool == "wget" then
    2     cmd = { "wget", "-q", "--user-agent=" .. USER_AGENT, "-O", dest_path, url }
        else
          -- PowerShell for Windows
   82     local ps_cmd = string.format(
   80       'Invoke-WebRequest -Uri "%s" -OutFile "%s" -UseBasicParsing -UserAgent "%s"',
   80       url, dest_path, USER_AGENT
    2     )
   34     cmd = { "powershell", "-Command", ps_cmd }
        end
        
   13   local result = vim.fn.system(cmd)
   59   local exit_code = vim.v.shell_error
        
        -- For curl, extract HTTP code from the end of output (since we used -w %{http_code})
   13   if tool == "curl" and result then
          -- The HTTP code is appended to stdout after the file is written
    9     http_code = result:match("(%d%d%d)$")
    9     if http_code then
    3       http_code = tonumber(http_code)
          end
        end
        
  599   if exit_code ~= 0 then
          -- Check if it's a command not found error vs network error
  586     local error_msg = result
****0     if result:match("command not found") or result:match("not installed") or result:match("is not recognized") then
****0       error_msg = tool .. " appears to be installed but execution failed: " .. result
          end
          
****0     return false, {
            message = error_msg,
            url = url,
            http_code = http_code,
            tool = tool,
            exit_code = exit_code,
            stderr = result,
          }
        end
        
        -- Verify file was downloaded and has reasonable size using vim.uv for cross-platform compatibility
   13   local uv = vim.uv or vim.loop
   13   local stat = uv.fs_stat(dest_path)
   13   if not stat or stat.size < 100 then
          -- Use vim.uv.fs_unlink for cross-platform file deletion
    6     uv.fs_unlink(dest_path)
    6     return false, {
            message = "Downloaded file is too small or empty",
    6       url = url,
    6       http_code = http_code or 200,
    6       tool = tool,
            exit_code = 0,
    6       stderr = "File size: " .. (stat and stat.size or 0) .. " bytes",
    6     }
        end
        
    7   return true, nil
      end

      ---Execute a shell command and return result
      ---Simple wrapper around vim.fn.system for consistency
      ---@param cmd table|string Command as array or string
      ---@return string output Command output
      ---@return number exit_code Exit code (0 = success)
   51 function M.system(cmd)
   10   local output = vim.fn.system(cmd)
   20   return output, vim.v.shell_error
      end

   51 return M

