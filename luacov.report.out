      ---HTTP download utilities
      ---@module hermes.download
      ---Provides a clean wrapper around HTTP download functionality with cross-platform support
      ---Uses curl (Unix), wget (Unix fallback), or PowerShell (Windows)

  586 local M = {}

      ---Check if curl is available on the system
      ---@return boolean available
  586 function M.is_curl_available()
  564   return vim.fn.executable("curl") == 1
      end

      ---Check if wget is available on the system
      ---@return boolean available
  586 function M.is_wget_available()
  202   return vim.fn.executable("wget") == 1
      end

      ---Check if PowerShell is available (Windows)
      ---@return boolean available
  586 function M.is_powershell_available()
  150   return vim.fn.executable("powershell") == 1
      end

      ---Get available download tool
      ---Priority: curl (Unix) > wget (Unix) > PowerShell (Windows)
      ---@return string|nil tool_name Name of available tool, or nil if none
  586 function M.get_available_tool()
  512   if M.is_curl_available() then
  168     return "curl"
  176   elseif M.is_wget_available() then
   26     return "wget"
  124   elseif M.is_powershell_available() then
   36     return "powershell"
        end
   26   return nil
      end

      ---Download file from URL using available tool
      ---Cross-platform: curl (Unix), wget (Unix fallback), PowerShell (Windows)
      ---@param url string URL to download
      ---@param dest_path string Destination path
      ---@return boolean success Whether download succeeded
      ---@return string|nil error Error message if failed
  586 function M.download(url, dest_path)
  121   local tool = M.get_available_tool()
        
  121   if not tool then
   13     return false, "No download tool available (tried curl, wget, PowerShell). Please install curl or wget."
        end
        
        local cmd
  108   if tool == "curl" then
   72     cmd = { "curl", "-sL", "-o", dest_path, url }
   36   elseif tool == "wget" then
   13     cmd = { "wget", "-q", "-O", dest_path, url }
        else
          -- PowerShell for Windows
   46     local ps_cmd = string.format(
   23       'Invoke-WebRequest -Uri "%s" -OutFile "%s" -UseBasicParsing',
   23       url, dest_path
   23     )
   23     cmd = { "powershell", "-Command", ps_cmd }
        end
        
  108   local result = vim.fn.system(cmd)
        
  216   if vim.v.shell_error ~= 0 then
          -- Check if it's a command not found error vs network error
   30     if result:match("command not found") or result:match("not installed") or result:match("is not recognized") then
    5       return false, tool .. " appears to be installed but execution failed: " .. result
          end
   25     return false, result
        end
        
        -- Verify file was downloaded and has reasonable size using vim.uv for cross-platform compatibility
   78   local uv = vim.uv or vim.loop
   78   local stat = uv.fs_stat(dest_path)
   78   if not stat or stat.size < 100 then
          -- Use vim.uv.fs_unlink for cross-platform file deletion
   32     uv.fs_unlink(dest_path)
   32     return false, "Downloaded file is too small or empty"
        end
        
   46   return true, nil
      end

      ---Execute a shell command and return result
      ---Simple wrapper around vim.fn.system for consistency
      ---@param cmd table|string Command as array or string
      ---@return string output Command output
      ---@return number exit_code Exit code (0 = success)
  586 function M.system(cmd)
   42   local output = vim.fn.system(cmd)
   84   return output, vim.v.shell_error
      end

  586 return M

