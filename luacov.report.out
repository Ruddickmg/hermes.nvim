      ---Version management for Hermes binaries
      ---@module hermes.version

  362 local M = {}

      ---Get the version to use
      ---Returns either user-specified version or "latest" as default
      ---@return string version Version string (e.g., "v0.1.0" or "latest")
  127 function M.get_wanted()
  292 	local config = require("hermes.config")
   57 	local wanted = config.get_version()

  292 	if wanted == "latest" then
   44 		return "latest"
      	end

      	-- Ensure version starts with 'v'
   13 	if not wanted:match("^v") then
    6 		wanted = "v" .. wanted
      	end

  104 	return wanted
      end

      ---Fetch latest release version from GitHub
      ---@return string version Latest version tag (e.g., "v0.1.0")
  127 function M.fetch_latest()
   29 	local logging = require("hermes.logging")
   29 	local fallback_version = "v0.1.0"

   37 	logging.notify("Fetching latest Hermes version from GitHub...", vim.log.levels.INFO)

      	-- Use download module for cross-platform HTTP support
   45 	local download = require("hermes.download")
  264 	local url = "https://api.github.com/repos/Ruddickmg/hermes.nvim/releases/latest"
      	
      	-- Create a temporary file for the response
   29 	local temp_file = os.tmpname()
      	
   29 	local success, err = download.download(url, temp_file)
      	
   29 	if not success then
      		-- Handle both structured error tables and plain strings
   16 		local err_msg = err
   16 		if type(err) == "table" and err.message then
    1 			err_msg = err.message
      		end
   78 		logging.notify("Failed to fetch latest version: " .. (err_msg or "Unknown error") .. ". Using fallback.", vim.log.levels.WARN)
   13 		os.remove(temp_file)
   13 		return fallback_version
      	end

      	-- Read the response
    3 	local f = io.open(temp_file, "r")
   78 	if not f then
   10 		logging.notify("Could not read version response. Using fallback.", vim.log.levels.WARN)
   85 		os.remove(temp_file)
****0 		return fallback_version
      	end
      	
   27 	local result = f:read("*all")
   27 	f:close()
      	
      	-- Clean up temp file
   13 	os.remove(temp_file)

      	-- Parse JSON response (simple pattern matching)
    3 	local tag = result:match('"tag_name":%s*"([^"]+)"')

    8 	if not tag then
    2 		logging.notify("Could not parse version from response. Using fallback.", vim.log.levels.WARN)
    7 		return fallback_version
      	end

   86 	logging.notify("Latest version: " .. tag, vim.log.levels.INFO)

   52 	return tag
      end

   93 return M

