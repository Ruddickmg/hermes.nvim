      	-- Suggest based on HTTP code
    5 	if err.http_code == 404 then
    1 		return "Version not found. Check available versions at: https://github.com/Ruddickmg/hermes.nvim/releases"
    4 	elseif err.http_code == 403 then
    1 		return "Download blocked. This may be due to rate limiting or network restrictions. Try building from source with :Hermes build"
  147 	elseif err.http_code == 401 then
****0 		return "Authentication required. Check if this is a private repository or try building from source."
    3 	elseif err.http_code and err.http_code >= 500 then
    1 		return "GitHub server error. Wait a moment and try again, or build from source with :Hermes build"
  146 	elseif err.message and err.message:match("too small") then
   65 		return "Download incomplete. This may be due to network issues. Try again or build from source with :Hermes build"
    1 	elseif err.message and err.message:match("No download tool available") then
    1 		return "Install curl or wget to enable automatic downloads, or build from source with :Hermes build"
      	end
      	
****0 	return "Try building from source with :Hermes build, or check your internet connection"
      end

