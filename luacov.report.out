      ---Platform detection utilities
      ---@module hermes.platform

 1206 local M = {}

      ---Get operating system
      ---@return string os_name Operating system: "linux", "macos", or "windows"
 1206 function M.get_os()
 2898   local uname = vim.loop.os_uname()
 2898   local sysname = uname.sysname
        
 2898   if sysname == "Linux" then
 2820     return "linux"
   78   elseif sysname == "Darwin" then
    1     return "macos"
   77   elseif sysname:match("Windows") or sysname:match("WIN") then
   15     return "windows"
        else
          -- Try to detect from vim functions
  185     if vim.fn.has("win32") == 1 or vim.fn.has("win64") == 1 then
    1       return "windows"
  168     elseif vim.fn.has("mac") == 1 or vim.fn.has("osx") == 1 then
   15       return "macos"
   92     elseif vim.fn.has("linux") == 1 then
   45       return "linux"
          end
          
    1     error("Unsupported operating system: " .. sysname)
        end
      end

      ---Get architecture
      ---@return string arch Architecture: "x86_64" or "aarch64"
 1206 function M.get_arch()
 1585   local machine = vim.loop.os_uname().machine
        
        -- Normalize architecture names
 1480   if machine == "x86_64" or machine == "amd64" or machine == "x64" then
 1390     return "x86_64"
   90   elseif machine == "aarch64" or machine == "arm64" then
   15     return "aarch64"
   75   elseif machine == "i386" or machine == "i686" then
   15     error("x86 (32-bit) architecture is not supported. Please use x86_64 or aarch64.")
        else
   60     error("Unsupported architecture: " .. machine .. ". Please use x86_64 or aarch64.")
        end
      end

      ---Get library extension for current platform
      ---@return string ext Library extension: "so", "dylib", or "dll"
 1206 function M.get_ext()
 1462   local os = M.get_os()
 1462   if os == "linux" then
 1432     return "so"
   30   elseif os == "macos" then
   15     return "dylib"
   15   elseif os == "windows" then
   15     return "dll"
        end
      end

      ---Get binary filename for current platform
      ---@return string filename Binary filename (e.g., "libhermes-linux-x86_64.so")
 1206 function M.get_binary_name()
  365   local os = M.get_os()
  365   local arch = M.get_arch()
  365   local ext = M.get_ext()
  365   return string.format("libhermes-%s-%s.%s", os, arch, ext)
      end

      ---Check if current platform is supported
      ---@return boolean supported Whether platform is supported
      ---@return string|nil error Error message if not supported
 1206 function M.is_supported()
   60   local ok, err = pcall(function()
   30     M.get_os()
   30     M.get_arch()
        end)
   30   return ok, err
      end

      ---Get platform string for display
      ---@return string platform Platform string (e.g., "Linux x86_64")
 1206 function M.get_display_string()
  274   local ok, os, arch = pcall(function()
  396     return M.get_os(), M.get_arch()
        end)
  137   if ok then
  122     return string.format("%s %s", os:gsub("^%l", string.upper), arch)
        else
   15     return "Unknown Platform"
        end
      end

      ---Get platform key for checking against supported platforms
      ---@return string|nil key Platform key (e.g., "linux-x86_64") or nil if not determinable
 1206 function M.get_platform_key()
 1174   local ok, os, arch = pcall(function()
 1746     return M.get_os(), M.get_arch()
        end)
  587   if ok then
  572     return string.format("%s-%s", os, arch)
        end
   15   return nil
      end

 1206 return M

